# Telegram (required)
API_ID=""
API_HASH=""
BOT_TOKEN=""
USER_SESSION_STRING=""
OWNER_ID=""

# Database (required — comma-separated URIs, exactly 2: tracking, storage_1)
DATABASE=""

# Server (required)
PORT="8000"


# Web session signing key (optional). If unset, a random key is generated on
# each boot (admins are logged out on restart). Set a long random value to
# keep sessions valid across restarts, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=""
