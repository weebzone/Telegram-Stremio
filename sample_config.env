# Startup Config
API_ID=""
API_HASH=""
BOT_TOKEN=""
HELPER_BOT_TOKEN=""
OWNER_ID=""
REPLACE_MODE="true"
HIDE_CATALOG="false"
PARALLEL="1"
PRE_FETCH="1"

# IPTV LIVE TV (iptv-org)
# India-only v1. When enabled, all playable Indian channels are indexed.
# Set IPTV_ENABLED="true" to advertise and synchronize the Live TV catalog.
IPTV_ENABLED="false"
IPTV_COUNTRY_CODES="IN"
IPTV_PAGE_SIZE="50"
IPTV_AUTO_SYNC="true"
IPTV_SYNC_INTERVAL_MINUTES="360"
IPTV_SYNC_START_DELAY_SECONDS="30"
IPTV_REQUEST_TIMEOUT_SEC="45"
IPTV_PROXY_TIMEOUT_SEC="30"
IPTV_PROXY_FALLBACK_ENABLED="true"
IPTV_PROXY_SECRET=""
IPTV_API_BASE_URL="https://iptv-org.github.io/api"

# STORAGE
AUTH_CHANNEL=""
DATABASE=""

# API
TMDB_API=""

# SERVER
BASE_URL=""
PORT="8000"

# UPDATE REPO
UPSTREAM_REPO="https://github.com/weebzone/Telegram-Stremio"
UPSTREAM_BRANCH="master"

# ADMIN PANNEL
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# SUBSCRIPTION CONFIG
SUBSCRIPTION=False                      #without ""
SUBSCRIPTION_GROUP_ID=                  #without ""
APPROVER_IDS= #without ""
SUBSCRIPTION_URL=""                     #telegram bot url like https://t.me/username

# PROXY CONFIG
Proxy=True
ProxyType=HTTPS
HTTP_Proxy_URL=""                       #example https://PROXYURL/?url=
SHOW_ProxyAndNonProxyBoth=True          #this will show both link proxy and non proxy both

